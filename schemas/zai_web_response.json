{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Z.AI Web Interface Response Schema",
  "description": "Schema for Z.AI web interface SSE streaming responses",
  "definitions": {
    "StreamingChunk": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["chat:completion", "chat:error", "chat:usage", "tool_call", "web_search"],
          "description": "Chunk type"
        },
        "data": {
          "$ref": "#/definitions/ChunkData",
          "description": "Chunk data payload"
        }
      }
    },
    "ChunkData": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["thinking", "content", "done", "tool_call"],
          "description": "Generation phase"
        },
        "delta_content": {
          "type": "string",
          "description": "Incremental content delta"
        },
        "content": {
          "type": "string",
          "description": "Full content (in done phase)"
        },
        "thinking_content": {
          "type": "string",
          "description": "Thinking/reasoning content"
        },
        "usage": {
          "$ref": "#/definitions/Usage",
          "description": "Token usage (in done phase)"
        },
        "finish_reason": {
          "type": "string",
          "enum": ["stop", "length", "tool_calls", "error"],
          "description": "Completion finish reason"
        },
        "tool_calls": {
          "type": "array",
          "items": {"$ref": "#/definitions/ToolCall"},
          "description": "Tool calls made by model"
        },
        "search_results": {
          "type": "array",
          "items": {"$ref": "#/definitions/SearchResult"},
          "description": "Web search results"
        }
      }
    },
    "Usage": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
      "properties": {
        "prompt_tokens": {
          "type": "integer",
          "description": "Tokens in prompt"
        },
        "completion_tokens": {
          "type": "integer",
          "description": "Tokens in completion"
        },
        "total_tokens": {
          "type": "integer",
          "description": "Total tokens used"
        }
      }
    },
    "ToolCall": {
      "type": "object",
      "required": ["id", "type", "function"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Tool call identifier"
        },
        "type": {
          "type": "string",
          "enum": ["function"],
          "description": "Tool type"
        },
        "function": {
          "type": "object",
          "required": ["name", "arguments"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Function name"
            },
            "arguments": {
              "type": "string",
              "description": "JSON string of arguments"
            }
          }
        }
      }
    },
    "SearchResult": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Search result title"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Result URL"
        },
        "snippet": {
          "type": "string",
          "description": "Content snippet"
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": ["type", "data"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["chat:error"],
          "description": "Error type"
        },
        "data": {
          "type": "object",
          "required": ["error"],
          "properties": {
            "error": {
              "type": "object",
              "required": ["message", "code"],
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Error message"
                },
                "code": {
                  "type": "string",
                  "description": "Error code"
                },
                "type": {
                  "type": "string",
                  "description": "Error type"
                }
              }
            }
          }
        }
      }
    }
  },
  "responseFormat": {
    "description": "Z.AI uses Server-Sent Events (SSE) format",
    "format": "text/event-stream",
    "example": "data: {\"type\":\"chat:completion\",\"data\":{\"phase\":\"content\",\"delta_content\":\"Hello\"}}\n\n"
  }
}

